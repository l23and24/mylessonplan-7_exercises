<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тренажер: Гідростатичний тиск</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="text/x-mathjax-config">
        MathJax.Hub.Config({
            showProcessingMessages: false,
            messageStyle: "none",
            extensions: ["tex2jax.js"],
            jax: ["input/TeX", "output/HTML-CSS"],
            tex2jax: {
                inlineMath: [['$','$'], ['\\(','\\)']],
                displayMath: [['$$','$$']]
            },
            "HTML-CSS": {
                scale: 100,
                availableFonts: ["TeX"],
                preferredFont: "TeX",
                webFont: "TeX",
                imageFont: null,
                linebreaks: { automatic: true }
            }
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.7/MathJax.js?config=TeX-AMS_HTML"></script>
    <style>
        body {
            height: 100vh;
            margin: 0;
            overflow: hidden;
            background: linear-gradient(180deg, #0ea5e9 0%, #075985 100%);
            font-family: system-ui, -apple-system, sans-serif;
        }
       
        .app-grid {
            display: grid;
            grid-template-columns: 1fr 400px;
            height: 100vh;
            padding: 20px;
            gap: 20px;
        }
       
        .ocean-area {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 32px;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            border: 2px solid rgba(255, 255, 255, 0.2);
            overflow: hidden;
            box-shadow: inset 0 0 100px rgba(0,0,0,0.2);
        }


        .main-formula-box {
            margin-top: 50px;
            background: white;
            padding: 25px 50px;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            text-align: center;
            z-index: 50;
        }


        .bubble-container {
            position: relative;
            width: 100%;
            height: 550px;
            display: flex;
            align-items: center;
            justify-content: center;
        }


        .bubble {
            position: absolute;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.1));
            border: 2px solid rgba(255, 255, 255, 0.6);
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: inset -10px -10px 20px rgba(255, 255, 255, 0.2), 0 10px 20px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(2px);
            z-index: 10;
        }


        .bubble:hover:not(.solved) {
            transform: scale(1.1);
            background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.2));
            border-color: #fff;
        }


        .bubble.active {
            border-color: #facc15;
            box-shadow: 0 0 40px rgba(250, 204, 21, 0.6);
            transform: scale(1.15);
            z-index: 30;
        }


        .bubble.solved {
            background: rgba(255, 255, 255, 0.95);
            border: 4px solid #0ea5e9;
            cursor: default;
        }


        .bubble.burst {
            animation: burst 0.5s forwards;
            pointer-events: none;
        }


        @keyframes burst {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.6); opacity: 0.5; border-width: 12px; }
            100% { transform: scale(2.2); opacity: 0; }
        }


        .sidebar {
            background: #ffffff;
            border-radius: 32px;
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
       
        .option-btn {
            width: 100%;
            padding: 15px;
            background: #f0f9ff;
            border: 2px solid #e0f2fe;
            border-radius: 16px;
            font-size: 1.25rem;
            cursor: pointer;
            transition: all 0.2s;
            min-height: 75px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0369a1;
            font-weight: 600;
        }


        .option-btn:hover {
            border-color: #0ea5e9;
            background: #e0f2fe;
            transform: translateY(-2px);
        }


        .option-btn.used { opacity: 0.15; pointer-events: none; filter: grayscale(1); }


        .win-overlay {
            position: absolute; inset: 0; background: rgba(7, 89, 133, 0.96);
            z-index: 100; display: none; flex-direction: column;
            align-items: center; justify-content: center; border-radius: 32px;
            color: white;
        }


        @keyframes float {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(8px, -15px); }
        }


        .floating {
            animation: float 4s ease-in-out infinite;
        }
    </style>
</head>
<body>


<div class="app-grid">
    <div class="ocean-area">
        <div class="main-formula-box">
            <h1 class="text-xs font-black text-sky-600 uppercase tracking-widest mb-1">Гідростатичний тиск</h1>
            <div class="text-4xl font-bold text-slate-800">
                $$p = \rho g h$$
            </div>
        </div>
       
        <div class="bubble-container" id="container">
            <!-- Бульбашки -->
        </div>


        <div id="win-screen" class="win-overlay">
            <div class="text-8xl mb-6">🐚</div>
            <h2 class="text-5xl font-black mb-2">ЧУДОВО!</h2>
            <p class="text-sky-200 text-xl">Ви опанували всі компоненти формули.</p>
            <button onclick="location.reload()" class="mt-10 bg-white text-sky-700 px-12 py-4 rounded-full font-bold shadow-2xl hover:bg-sky-50 transition-all uppercase tracking-widest">Ще раз</button>
        </div>
    </div>


    <div class="sidebar">
        <div>
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Завдання</h3>
            <div id="status" class="bg-sky-50 border-2 border-sky-100 p-6 rounded-2xl text-center font-bold text-sky-900 text-xl min-h-[110px] flex items-center justify-center">
                Оберіть бульбашку, щоб вивести формулу
            </div>
        </div>
       
        <div class="flex-1 flex flex-col overflow-hidden">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Варіанти відповідей</h3>
            <div id="bank" class="grid grid-cols-1 gap-3 overflow-y-auto pr-2">
                <!-- Кнопки -->
            </div>
        </div>


        <div class="bg-slate-50 p-5 rounded-xl border border-dashed border-slate-200">
            <div class="text-[11px] text-slate-500 text-center leading-relaxed font-medium">
                $\rho$ — густина рідини ($кг/м^3$)<br>
                $g$ — прискорення вільного падіння ($Н/кг$)<br>
                $h$ — глибина ($м$)
            </div>
        </div>
    </div>
</div>


<script>
    // Тільки основні величини тепер мають власні бульбашки
    const data = [
        { id: 0, label: '$p$', formula: '$\\rho g h$', x: -180, y: -80 },
        { id: 1, label: '$\\rho$', formula: '$\\frac{p}{g h}$', x: 180, y: -80 },
        { id: 2, label: '$g$', formula: '$\\frac{p}{\\rho h}$', x: -180, y: 120 },
        { id: 3, label: '$h$', formula: '$\\frac{p}{\\rho g}$', x: 180, y: 120 }
    ];


    const distractors = [
        '$\\frac{\\rho g}{p}$',
        '$\\frac{p \\rho}{g}$',
        '$\\frac{g h}{p}$',
        '$p \\cdot \\rho \\cdot g$',
        '$\\sqrt{\\rho g h}$'
    ];
   
    let selectedIdx = -1;
    let solvedCount = 0;
    let audioCtx = null;


    function playSound(freq, type = 'sine') {
        try {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const o = audioCtx.createOscillator();
            const g = audioCtx.createGain();
            o.type = type; o.connect(g); g.connect(audioCtx.destination);
            o.frequency.value = freq;
            g.gain.setValueAtTime(0.1, audioCtx.currentTime);
            g.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
            o.start(); o.stop(audioCtx.currentTime + 0.4);
        } catch(e) {}
    }


    function init() {
        const container = document.getElementById('container');
        const bank = document.getElementById('bank');


        data.forEach((item, i) => {
            const b = document.createElement('div');
            b.className = 'bubble floating';
            b.id = `b-${i}`;
            b.style.left = `calc(50% + ${item.x}px - 75px)`;
            b.style.top = `calc(50% + ${item.y}px - 75px)`;
            b.style.animationDelay = `${Math.random() * 2}s`;
           
            b.innerHTML = `<span class="text-sky-800 font-black text-4xl">${item.label}</span>`;
            b.onclick = () => select(i);
            container.appendChild(b);
        });


        const options = [...data.map(d => d.formula), ...distractors].sort(() => Math.random() - 0.5);
        options.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'option-btn';
            btn.innerHTML = opt;
            btn.onclick = () => check(opt, btn);
            bank.appendChild(btn);
        });


        if (window.MathJax) MathJax.Hub.Queue(["Typeset", MathJax.Hub]);
    }


    function select(i) {
        if (data[i].done) return;
        selectedIdx = i;
        document.querySelectorAll('.bubble').forEach(b => b.classList.remove('active'));
        document.getElementById(`b-${i}`).classList.add('active');
        document.getElementById('status').innerHTML = `Виразіть: <span class="text-sky-600 ml-2">${data[i].label}</span>`;
        if (window.MathJax) MathJax.Hub.Queue(["Typeset", MathJax.Hub, document.getElementById('status')]);
    }


    function check(val, btn) {
        if (selectedIdx === -1) return;
       
        const bubble = document.getElementById(`b-${selectedIdx}`);
       
        if (val === data[selectedIdx].formula) {
            playSound(600, 'sine');
            data[selectedIdx].done = true;
            bubble.classList.remove('active', 'floating');
            bubble.classList.add('solved');
           
            bubble.innerHTML = `
                <span class="text-sky-500 font-bold text-[11px] mb-1">${data[selectedIdx].label} =</span>
                <div class="text-xl font-bold text-slate-800">${val}</div>
            `;
           
            btn.classList.add('used');
            selectedIdx = -1;
            solvedCount++;
            document.getElementById('status').innerText = "Правильно!";
           
            if (solvedCount === data.length) {
                setTimeout(() => {
                    document.getElementById('win-screen').style.display = 'flex';
                    playSound(400, 'triangle');
                    playSound(800, 'triangle');
                }, 500);
            }
        } else {
            playSound(150, 'square');
            bubble.classList.add('burst');
            selectedIdx = -1;
            document.getElementById('status').innerText = "Помилка! Бульбашка луснула.";
           
            setTimeout(() => {
                bubble.classList.remove('burst', 'active');
                void bubble.offsetWidth;
            }, 600);
        }
       
        if (window.MathJax) MathJax.Hub.Queue(["Typeset", MathJax.Hub, bubble]);
    }


    window.onload = init;
</script>


</body>
</html>
